<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<HBox alignment="CENTER_LEFT" prefHeight="38.0" prefWidth="360.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.SetController">
    <children>
        <Label fx:id="setIdLabel" alignment="CENTER" contentDisplay="CENTER" minWidth="20.0" prefHeight="25.0" prefWidth="39.0" style="-fx-background-color: #222;" text="1" textAlignment="CENTER" textFill="#eeeeee">
            <font>
                <Font size="16.0" />
            </font>
        </Label>
        <Label alignment="CENTER" contentDisplay="CENTER" minWidth="53.0" prefHeight="20.0" prefWidth="68.0" style="-fx-background-color: #222;" text="-" textAlignment="CENTER" textFill="#eeeeee">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <TextField fx:id="repsLabel" alignment="CENTER" maxWidth="70.0" onKeyTyped="#validateInput" prefHeight="28.0" prefWidth="73.0" promptText="0" style="-fx-background-color: #333; -fx-text-fill: #eee;">
         <HBox.margin>
            <Insets left="10.0" />
         </HBox.margin></TextField>
        <Button maxWidth="30.0" mnemonicParsing="false" onAction="#removeSet" prefHeight="28.0" prefWidth="92.0" style="-fx-background-color: #333; -fx-border-radius: 4; -fx-background-radius: 4;" text="❌" textFill="#ca0000">
            <font>
                <Font size="8.0" />
            </font>
         <HBox.margin>
            <Insets left="60.0" />
         </HBox.margin>
        </Button>
    </children>
    <opaqueInsets>
        <Insets />
    </opaqueInsets>
   <padding>
      <Insets left="10.0" />
   </padding>
</HBox>
