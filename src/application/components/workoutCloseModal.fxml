<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="137.0" prefWidth="346.0" style="-fx-background-color: #333;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.NewWorkoutController">
   <children>
      <Label layoutX="101.0" layoutY="24.0" text="Are you sure?" textFill="#eeeeee">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
      <Button fx:id="cancelButton" layoutX="66.0" layoutY="75.0" mnemonicParsing="false" onAction="#closeModal" styleClass="button-cancel" stylesheets="@../application.css" text="Cancel" textFill="#eeeeee">
         <font>
            <Font size="16.0" />
         </font>
      </Button>
      <Button fx:id="discardButton" layoutX="145.0" layoutY="75.0" mnemonicParsing="false" onAction="#goToMainView" style="-fx-background-color: #a60303; -fx-border-color: #a60303;" styleClass="button-cancel" stylesheets="@../application.css" text="Discard workout" textFill="#eeeeee">
         <font>
            <Font size="16.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
