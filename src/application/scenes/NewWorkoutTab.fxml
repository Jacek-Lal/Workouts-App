<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="mainContainer" prefHeight="600.0" prefWidth="900.0" styleClass="greyContainer" stylesheets="@../application.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controllers.NewWorkoutController">
   <children>
      <Pane prefHeight="600.0" prefWidth="265.0" style="-fx-background-color: #222;" styleClass=".side_pane">
         <children>
            <Button id="finishWorkoutButton" layoutX="93.0" layoutY="450.0" mnemonicParsing="false" onAction="#saveWorkout" prefHeight="80.0" prefWidth="80.0" text="Save" textFill="#eeeeee">
               <font>
                  <Font size="20.0" />
               </font>
               <styleClass>
                  <String fx:value="buttonPurple" />
                  <String fx:value="button" />
               </styleClass>
            </Button>
            <Label fx:id="workoutNameLabel" alignment="CENTER" layoutX="49.0" layoutY="28.0" prefHeight="98.0" prefWidth="169.0" text="Workout Title" textAlignment="CENTER" textFill="#eeeeee" wrapText="true">
               <font>
                  <Font size="25.0" />
               </font>
            </Label>
            <Label layoutX="44.0" layoutY="142.0" text="Volume" textFill="#eeeeee">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
            <Label alignment="CENTER_RIGHT" layoutX="183.0" layoutY="142.0" text="Sets" textFill="#eeeeee">
               <font>
                  <Font size="16.0" />
               </font>
            </Label>
            <Label fx:id="totalWeightLabel" alignment="CENTER" layoutX="37.0" layoutY="167.0" prefHeight="20.0" prefWidth="66.0" text="0" textFill="#eeeeee">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <Label fx:id="totalSetsLabel" alignment="CENTER" layoutX="165.0" layoutY="167.0" prefHeight="20.0" prefWidth="66.0" text="0" textFill="#eeeeee">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
         </children>
      </Pane>
      <Button fx:id="addExerciseButton" layoutX="416.0" layoutY="521.0" mnemonicParsing="false" onAction="#showExercises" prefHeight="38.0" prefWidth="320.0" styleClass="button-ok" text="Add exercise" textFill="#eeeeee">
         <font>
            <Font size="16.0" />
         </font>
      </Button>
      <ScrollPane fx:id="exercisesScrollPane" hbarPolicy="NEVER" hmin="10.0" hvalue="10.0" layoutX="359.0" layoutY="49.0" prefHeight="451.0" prefWidth="434.0" style="-fx-background-color: #333;" vbarPolicy="NEVER">
         <content>
            <VBox fx:id="exercisesContainer" prefHeight="451.0" prefWidth="433.0" style="-fx-background-color: #222;" />
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
